{
  "created": 1718790000000,
  "updated": 1718790000000,
  "name": "Admission_Flow - greenwood-sms",
  "description": "Handles admission inquiry submissions, stores them in Supabase, sends confirmation brochure via Gmail, and adds an admin verification task.",
  "tags": [
    "Greenwood Juniors",
    "Admissions"
  ],
  "pieces": [
    "@puchoaistudio/tool-gmail",
    "@puchoaistudio/tool-supabase",
    "@puchoaistudio/tool-todos",
    "@puchoaistudio/tool-webhook"
  ],
  "template": {
    "displayName": "Admission Inquiry Flow",
    "trigger": {
      "name": "trigger",
      "type": "PIECE_TRIGGER",
      "displayName": "Admission Webhook Listener",
      "valid": true,
      "settings": {
        "pieceName": "@puchoaistudio/tool-webhook",
        "pieceVersion": "2.0.4",
        "triggerName": "catch_webhook",
        "input": {
          "authType": "none"
        },
        "propertySettings": {
          "authType": {
            "type": "MANUAL"
          },
          "authFields": {
            "type": "MANUAL",
            "schema": {}
          },
          "liveMarkdown": {
            "type": "MANUAL"
          },
          "syncMarkdown": {
            "type": "MANUAL"
          },
          "testMarkdown": {
            "type": "MANUAL"
          }
        },
        "sampleData": {}
      },
      "nextAction": {
        "name": "adm_db_insert",
        "type": "PIECE",
        "displayName": "Insert Admissions Lead",
        "skip": false,
        "valid": true,
        "settings": {
          "pieceName": "@puchoaistudio/tool-supabase",
          "pieceVersion": "2.0.0",
          "actionName": "create_row",
          "input": {
            "table": "admissions",
            "values": {
              "id": "ADM-{{trigger['body']['payload']['parent_name'].substring(0,3)}}-{{trigger['body']['payload']['phone'].substring(6)}}",
              "student_name": "{{trigger['body']['payload']['student_name']}}",
              "parent_name": "{{trigger['body']['payload']['parent_name']}}",
              "grade": "{{trigger['body']['payload']['grade']}}",
              "dob": "{{trigger['body']['payload']['dob']}}",
              "phone": "{{trigger['body']['payload']['phone']}}",
              "parent_email": "{{trigger['body']['payload']['email']}}",
              "status": "Pending",
              "address": "{{trigger['body']['payload']['address']}}"
            }
          },
          "propertySettings": {
            "table": {
              "type": "MANUAL"
            },
            "values": {
              "type": "MANUAL"
            }
          }
        },
        "nextAction": {
          "name": "adm_email_prospectus",
          "type": "PIECE",
          "displayName": "Email Welcome Brochure",
          "skip": false,
          "valid": true,
          "settings": {
            "pieceName": "@puchoaistudio/tool-gmail",
            "pieceVersion": "2.0.4",
            "actionName": "send_email",
            "input": {
              "to": "{{trigger['body']['payload']['email']}}",
              "subject": "Welcome to Greenwood Juniors Early Learning Centre!",
              "text": "Dear {{trigger['body']['payload']['parent_name']}},\n\nThank you for inquiring about admission for {{trigger['body']['payload']['student_name']}} in our {{trigger['body']['payload']['grade']}} program.\n\nWe have received your request, and our admission counselor will contact you at {{trigger['body']['payload']['phone']}} shortly.\n\nWarm regards,\nGreenwood Juniors Team",
              "auth": ""
            },
            "propertySettings": {
              "auth": {
                "type": "MANUAL"
              },
              "to": {
                "type": "MANUAL"
              },
              "subject": {
                "type": "MANUAL"
              },
              "text": {
                "type": "MANUAL"
              }
            }
          },
          "nextAction": {
            "name": "adm_create_admin_todo",
            "type": "PIECE",
            "displayName": "Create Admin Verification Task",
            "skip": false,
            "valid": true,
            "settings": {
              "pieceName": "@puchoaistudio/tool-todos",
              "pieceVersion": "2.0.0",
              "actionName": "createTodo",
              "input": {
                "title": "Review Admission: {{trigger['body']['payload']['student_name']}}",
                "description": "Parent Name: {{trigger['body']['payload']['parent_name']}}\nPhone: {{trigger['body']['payload']['phone']}}\nProgram: {{trigger['body']['payload']['grade']}}",
                "statusOptions": [
                  {
                    "name": "Review Pending",
                    "variant": "Neutral (Gray)",
                    "continueFlow": true
                  },
                  {
                    "name": "Contacted",
                    "variant": "Positive (Green)",
                    "continueFlow": true
                  },
                  {
                    "name": "Rejected",
                    "variant": "Negative (Red)",
                    "continueFlow": true
                  }
                ]
              },
              "propertySettings": {
                "title": {
                  "type": "MANUAL"
                },
                "description": {
                  "type": "MANUAL"
                },
                "statusOptions": {
                  "type": "MANUAL"
                }
              }
            },
            "nextAction": {
              "name": "adm_return_response",
              "type": "PIECE",
              "displayName": "Return Success Message",
              "skip": false,
              "valid": true,
              "settings": {
                "pieceName": "@puchoaistudio/tool-webhook",
                "pieceVersion": "2.0.4",
                "actionName": "return_response",
                "input": {
                  "responseType": "json",
                  "respond": "stop",
                  "fields": {
                    "success": true,
                    "message": "Admission inquiry submitted successfully and review task generated."
                  }
                },
                "propertySettings": {
                  "responseType": {
                    "type": "MANUAL"
                  },
                  "respond": {
                    "type": "MANUAL"
                  },
                  "fields": {
                    "type": "MANUAL",
                    "schema": {
                      "success": {
                        "type": "BOOLEAN"
                      },
                      "message": {
                        "type": "SHORT_TEXT"
                      }
                    }
                  }
                }
              },
              "nextAction": null
            }
          },
          "errorHandlingOptions": {
            "retryOnFailure": {
              "value": false
            },
            "continueOnFailure": {
              "value": true
            }
          }
        },
        "errorHandlingOptions": {
          "retryOnFailure": {
            "value": true
          },
          "continueOnFailure": {
            "value": false
          }
        }
      }
    },
    "valid": true,
    "agentIds": [],
    "connectionIds": [],
    "schemaVersion": "7"
  },
  "blogUrl": ""
}