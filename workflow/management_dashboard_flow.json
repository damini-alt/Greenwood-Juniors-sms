            "nextAction": {
              "name": "sal_loop_teachers",
              "type": "LOOP_ON_ITEMS",
              "displayName": "Loop through staff for salary calculation",
              "settings": {
                "items": "{{sal_fetch_staff['body']}}"
              },
              "firstLoopAction": {
                "name": "sal_fetch_leaves",
                "type": "PIECE",
                "displayName": "Fetch Staff Leaves",
                "skip": false,
                "valid": true,
                "settings": {
                  "pieceName": "@puchoaistudio/tool-http",
                  "pieceVersion": "2.0.0",
                  "actionName": "send_request",
                  "input": {
                    "method": "GET",
                    "url": "https://ajaybezpuilzcfnisapm.supabase.co/rest/v1/leaves?user_id=eq.{{sal_loop_teachers['item']['employee_id']}}&status=eq.Approved",
                    "headers": {
                      "apikey": "YOUR_SUPABASE_ANON_KEY",
                      "Authorization": "Bearer YOUR_SUPABASE_ANON_KEY"
                    },
                    "authType": "none"
                  },
                  "propertySettings": {
                    "method": {
                      "type": "MANUAL"
                    },
                    "url": {
                      "type": "MANUAL"
                    },
                    "headers": {
                      "type": "MANUAL"
                    },
                    "authType": {
                      "type": "MANUAL"
                    }
                  }
                },
                "nextAction": {
                  "name": "sal_code_calculate",
                  "type": "CODE",
                  "displayName": "Calculate Salary Payout",
                  "skip": false,
                  "valid": true,
                  "settings": {
                    "input": {
                      "base": "{{sal_loop_teachers['item']['basic_salary'] || 25000}}",
                      "approvedLeaves": "{{sal_fetch_leaves['body'].length || 0}}"
                    },
                    "sourceCode": {
                      "code": "export const code = async (inputs) => {\n  const base = parseFloat(inputs.base);\n  const leaves = parseInt(inputs.approvedLeaves);\n  const extraLeaves = Math.max(0, leaves - 2);\n  const deduction = extraLeaves * 1000;\n  const netSalary = Math.max(0, base - deduction);\n  return { base, leaves, deduction, netSalary };\n};",
                      "packageJson": "{}"
                    },
                    "propertySettings": {
                      "sourceCode": {
                        "type": "MANUAL"
                      }
                    }
                  },
                  "nextAction": {
                    "name": "sal_post_payslip",
                    "type": "PIECE",
                    "displayName": "Post Payslip to DB",
                    "skip": false,
                    "valid": true,
                    "settings": {
                      "pieceName": "@puchoaistudio/tool-supabase",
                      "pieceVersion": "2.0.0",
                      "actionName": "create_row",
                      "input": {
                        "table": "payslips",
                        "values": {
                          "employee_id": "{{sal_loop_teachers['item']['employee_id']}}",
                          "month": "Current Month",
                          "base_salary": "{{sal_code_calculate['base']}}",
                          "net_salary": "{{sal_code_calculate['netSalary']}}",
                          "present_days": 24,
                          "absent_days": "{{sal_code_calculate['leaves']}}",
                          "status": "Paid"
                        }
                      },
                      "propertySettings": {
                        "table": {
                          "type": "MANUAL"
                        },
                        "values": {
                          "type": "MANUAL"
                        }
                      }
                    },
                    "errorHandlingOptions": {
                      "retryOnFailure": {
                        "value": true
                      },
                      "continueOnFailure": {
                        "value": false
                      }
                    },
                    "nextAction": {
                      "name": "sal_email_payslip",
                      "type": "PIECE",
                      "displayName": "Email payslip",
                      "skip": false,
                      "valid": true,
                      "settings": {
                        "pieceName": "@puchoaistudio/tool-gmail",
                        "pieceVersion": "2.0.4",
                        "actionName": "send_email",
                        "input": {
                          "auth": "",
                          "to": "{{sal_loop_teachers['item']['email']}}",
                          "subject": "Monthly Payslip Generated - Greenwood Juniors HR",
                          "text": "Dear {{sal_loop_teachers['item']['name']}},\n\nYour salary payslip has been generated.\n\nBase Salary: ₹{{sal_code_calculate['base']}}\nLeaves Taken: {{sal_code_calculate['leaves']}} days\nDeductions: ₹{{sal_code_calculate['deduction']}}\nNet Salary Transferred: ₹{{sal_code_calculate['netSalary']}}\n\nPlease review your bank details.\n\nWarm regards,\nGreenwood Juniors HR"
                        },
                        "propertySettings": {
                          "auth": {
                            "type": "MANUAL"
                          },
                          "to": {
                            "type": "MANUAL"
                          },
                          "subject": {
                            "type": "MANUAL"
                          },
                          "text": {
                            "type": "MANUAL"
                          }
                        }
                      },
                      "errorHandlingOptions": {
                        "retryOnFailure": {
                          "value": false
                        },
                        "continueOnFailure": {
                          "value": true
                        }
                      },
                      "nextAction": null
                    }
                  }
                }
              },
              "nextAction": {
                "name": "sal_return_response",
                "type": "PIECE",
                "displayName": "Return Payroll Status",
                "skip": false,
                "valid": true,
                "settings": {
                  "pieceName": "@puchoaistudio/tool-webhook",
                  "pieceVersion": "2.0.4",
                  "actionName": "return_response",
                  "input": {
                    "responseType": "json",
                    "respond": "stop",
                    "fields": {
                      "success": true,
