                  "actionName": "send_email",
                  "input": {
                    "auth": "",
                    "to": "{{fee_loop_invoices['item']['parent_email'] || 'parent@school.com'}}",
                    "subject": "Overdue Fee Notice - Greenwood Juniors Academy",
                    "text": "Dear Parent,\n\nThis is a friendly reminder that the fee payment of ₹{{fee_loop_invoices['item']['amount']}} for {{fee_loop_invoices['item']['type']}} is currently outstanding.\n\nDue Date: {{fee_loop_invoices['item']['due_date']}}\nStatus: Pending\n\nPlease make the payment through the parent portal.\n\nWarm regards,\nGreenwood Juniors Accounts"
                  },
                  "propertySettings": {
