{
  "created": 1718790000000,
  "updated": 1718790000000,
  "name": "Management_Dashboard_Flow - greenwood-sms",
  "description": "Orchestrates administrative tasks from the school management portal. Routes requests based on action (homework_broadcast, salary_calculation, fee_reminder).",
  "tags": [
    "Greenwood Juniors",
    "Management",
    "Staff"
  ],
  "pieces": [
    "@puchoaistudio/tool-gmail",
    "@puchoaistudio/tool-http",
    "@puchoaistudio/tool-supabase",
    "@puchoaistudio/tool-webhook"
  ],
  "template": {
    "displayName": "Management Dashboard Flow",
    "trigger": {
      "name": "trigger",
      "type": "PIECE_TRIGGER",
      "displayName": "Management Webhook Listener",
      "valid": true,
      "settings": {
        "pieceName": "@puchoaistudio/tool-webhook",
        "pieceVersion": "2.0.4",
        "triggerName": "catch_webhook",
        "input": {
          "authType": "none"
        },
        "propertySettings": {
          "authType": {
            "type": "MANUAL"
          },
          "authFields": {
            "type": "MANUAL",
            "schema": {}
          },
          "liveMarkdown": {
            "type": "MANUAL"
          },
          "syncMarkdown": {
            "type": "MANUAL"
          },
          "testMarkdown": {
            "type": "MANUAL"
          }
        },
        "sampleData": {}
      },
      "nextAction": {
        "name": "router_step",
        "type": "ROUTER",
        "displayName": "Route Management Action Type",
        "valid": true,
        "settings": {
          "executionType": "EXECUTE_FIRST_MATCH",
          "branches": [
            {
              "name": "Homework Broadcast Branch",
              "conditions": [
                [
                  {
                    "operator": "TEXT_EXACTLY_MATCHES",
                    "firstValue": "{{trigger['body']['action']}}",
                    "secondValue": "homework_broadcast"
                  }
                ]
              ]
            },
            {
              "name": "Salary Calculation Branch",
              "conditions": [
                [
                  {
                    "operator": "TEXT_EXACTLY_MATCHES",
                    "firstValue": "{{trigger['body']['action']}}",
                    "secondValue": "salary_calculation"
                  }
                ]
              ]
            },
            {
              "name": "Fee Outstanding Reminders Branch",
              "conditions": [
                [
                  {
                    "operator": "TEXT_EXACTLY_MATCHES",
                    "firstValue": "{{trigger['body']['action']}}",
                    "secondValue": "fee_reminder"
                  }
                ]
              ]
            }
          ]
        },
        "children": [
          {
            "name": "hw_fetch_parents",
            "type": "PIECE",
            "displayName": "Fetch Parent Contacts",
            "skip": false,
            "valid": true,
            "settings": {
              "pieceName": "@puchoaistudio/tool-http",
              "pieceVersion": "2.0.0",
              "actionName": "send_request",
              "input": {
                "method": "GET",
                "url": "https://ajaybezpuilzcfnisapm.supabase.co/rest/v1/students?select=parent_email,admission_no,profiles:profiles(full_name)&section_id=eq.{{trigger['body']['payload']['section_id']}}",
                "headers": {
                  "apikey": "YOUR_SUPABASE_ANON_KEY",
                  "Authorization": "Bearer YOUR_SUPABASE_ANON_KEY"
                },
                "authType": "none"
              },
              "propertySettings": {
                "method": {
                  "type": "MANUAL"
                },
                "url": {
                  "type": "MANUAL"
                },
                "headers": {
                  "type": "MANUAL"
                },
                "authType": {
                  "type": "MANUAL"
                }
              }
            },
            "nextAction": {
              "name": "hw_loop_students",
              "type": "LOOP_ON_ITEMS",
              "displayName": "Loop through Students",
              "settings": {
                "items": "{{hw_fetch_parents['body']}}"
              },
              "firstLoopAction": {
                "name": "hw_email_parent",
                "type": "PIECE",
                "displayName": "Send Homework Alert",
                "skip": false,
                "valid": true,
                "settings": {
                  "pieceName": "@puchoaistudio/tool-gmail",
                  "pieceVersion": "2.0.4",
                  "actionName": "send_email",
                  "input": {
                    "auth": "",
                    "to": "{{hw_loop_students['item']['parent_email']}}",
                    "subject": "New Homework: {{trigger['body']['payload']['title']}}",
                    "text": "Dear Parent,\n\nNew homework has been assigned for your child.\n\nSubject: {{trigger['body']['payload']['subject']}}\nTitle: {{trigger['body']['payload']['title']}}\nDescription: {{trigger['body']['payload']['description']}}\nDue Date: {{trigger['body']['payload']['due_date']}}\nAssigned By: {{trigger['body']['payload']['assigned_by']}}\n\nPlease assist your child in completing it.\n\nWarm regards,\nGreenwood Juniors Academy"
                  },
                  "propertySettings": {
                    "auth": {
                      "type": "MANUAL"
                    },
                    "to": {
                      "type": "MANUAL"
                    },
                    "subject": {
                      "type": "MANUAL"
                    },
                    "text": {
                      "type": "MANUAL"
                    }
                  }
                },
                "errorHandlingOptions": {
                  "retryOnFailure": {
                    "value": false
                  },
                  "continueOnFailure": {
                    "value": true
                  }
                },
                "nextAction": null
              },
              "nextAction": {
                "name": "hw_return_response",
                "type": "PIECE",
                "displayName": "Return Broadcast Summary",
                "skip": false,
                "valid": true,
                "settings": {
                  "pieceName": "@puchoaistudio/tool-webhook",
                  "pieceVersion": "2.0.4",
                  "actionName": "return_response",
                  "input": {
                    "responseType": "json",
                    "respond": "stop",
                    "fields": {
                      "success": true,
                      "message": "Homework broadcast emails sent successfully to all section parents."
                    }
                  },
                  "propertySettings": {
                    "responseType": {
                      "type": "MANUAL"
                    },
                    "respond": {
                      "type": "MANUAL"
                    },
                    "fields": {
                      "type": "MANUAL",
                      "schema": {
                        "success": {
                          "type": "BOOLEAN"
                        },
                        "message": {
                          "type": "SHORT_TEXT"
                        }
                      }
                    }
                  }
                },
                "errorHandlingOptions": {
                  "retryOnFailure": {
                    "value": false
                  },
                  "continueOnFailure": {
                    "value": true
                  }
                },
                "nextAction": null
              }
            }
          },
          {
            "name": "sal_fetch_staff",
            "type": "PIECE",
            "displayName": "Fetch Staff Members",
            "skip": false,
            "valid": true,
            "settings": {
              "pieceName": "@puchoaistudio/tool-http",
              "pieceVersion": "2.0.0",
              "actionName": "send_request",
              "input": {
                "method": "GET",
                "url": "https://ajaybezpuilzcfnisapm.supabase.co/rest/v1/staff?select=*",
                "headers": {
                  "apikey": "YOUR_SUPABASE_ANON_KEY",
                  "Authorization": "Bearer YOUR_SUPABASE_ANON_KEY"
                },
                "authType": "none"
